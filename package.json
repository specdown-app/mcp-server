{
  "name": "specdown-mcp",
  "version": "1.0.5",
  "description": "AI-native MCP server for SpecDown — let AI assistants read, search, and edit your Markdown spec docs. Spec as Code for AI-native teams.",
  "main": "dist/index.js",
  "bin": {
    "specdown-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "markdown",
    "spec",
    "documentation",
    "ai",
    "claude",
    "cursor",
    "specdown",
    "spec-as-code",
    "ai-native",
    "ai-native-mcp",
    "ai-operable",
    "markdown-mcp",
    "ai-native-documentation",
    "spec-driven",
    "ai-native-devtools"
  ],
  "author": "SpecDown <hello@specdown.app>",
  "license": "MIT",
  "homepage": "https://specdown.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specdown-app/mcp-server.git"
  },
  "bugs": "https://github.com/specdown-app/mcp-server/issues",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
